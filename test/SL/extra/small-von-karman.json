{
    "dx": 2e-3,
    "dy": 2e-3,
    "dt": 1e-3,
    "nx": 150,
    "ny": 80,
    "nt": 1000,
    "density": 1000,
    "sampling_rate": 5,
    "write_smoke":         true,
    "write_u":             true,
    "write_v":             true,
    "write_p":             true,
    "write_div":           true,
    "write_norm_velocity": true,

    "folder":   "results/SL/small-vk",
    "filename": "simulation",


    "velocityu": {
        "rectangle": {
            "condition": "boundary",
            "val": 1,
            "x1": "0",
            "y1": "0",
            "x2": "0",
            "y2": "ny"
        }
    },

    "solid": {
        "cylinder": {
            "x": "nx/6",
            "y": "ny/2",
            "r": "ny/10"
        },

        "rectangle":[{
            "x1": "0",
            "y1": "ny+1",
            "x2": "nx+1",
            "y2": "ny+1"
        },
        {
            "x1": "0",
            "y1": "0",
            "x2": "nx+1",
            "y2": "0"
        }]
    },

    "smoke": {
        "rectangle": {
            "condition": "boundary",
            "val": 1,
            "x1": "0",
            "y1": "0",
            "x2": "0",
            "y2": "ny"
        }
    },

    "solver": {
  "type": "cg",
    "max_iterations": 1e5,
    "tolerance": 1e-2
}
}

