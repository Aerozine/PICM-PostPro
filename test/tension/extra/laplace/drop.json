{
    "dx": 0.02,
    "dy": 0.02,
    "dt": 0.025,
    "nx": 30,
    "ny": 30,
    "nt": 500,
    "ppcx": 2,
    "ppcy": 2,
    "density": 1000,
    "sampling_rate": 10,
    "write_u": true,
    "write_v": true,
    "write_p": true,
    "write_div": true,
    "write_norm_velocity": true,
    "write_smoke": true,
    "write_particles": true,
    "folder": "results/PIC/surfaceTension/laplace/drop",
    "filename": "simulation",

    "fluid": {
        "cylinder": {
            "x": "nx/2",
            "y": "ny/4",
            "r": "ny/4"
        }
    },

    "solid": {
        "rectangle":[{
            "x1": "0",
            "y1": "0",
            "x2": "nx+1",
            "y2": "0"
        },
        {
            "x1": "0",
            "y1": "ny+1",
            "x2": "nx+1",
            "y2": "ny+1"
        },
        {
            "x1": "0",
            "y1": "0",
            "x2": "0",
            "y2": "ny+1"
        },
        {
            "x1": "nx+1",
            "y1": "0",
            "x2": "nx+1",
            "y2": "ny+1"
        }]
    },


    "solver": {
        "type": "red_black_gauss_seidel",
        "max_iterations": 1e5,
        "tolerance": 1e-2
    },
    "method": "pic",
    "freeSurface": "yes",
    "gravity": 0.0,
    "refill": false,
    "surfaceTension": true,
    "particleInteraction": false,
    "gamma": 0.073
}