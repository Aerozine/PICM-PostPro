#!/usr/bin/env python3
"""Convert all particles.pvd files in a folder to MP4s.

Usage: ./particletomp4 <folder> [--fps 30] [--cmap viridis] [--workers 4] [--crf 24]
"""
from __future__ import annotations

import argparse
import sys
from pathlib import Path

# Make sure the PostPro package is importable
_SCRIPT_DIR = Path(__file__).resolve().parent
if str(_SCRIPT_DIR) not in sys.path:
    sys.path.insert(0, str(_SCRIPT_DIR))

from particles_to_mp4 import parse_pvd, build_mp4


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("folder", type=Path, help="folder to search for particles.pvd")
    parser.add_argument("--fps", type=int, default=30)
    parser.add_argument("--cmap", default="viridis")
    parser.add_argument("--workers", type=int, default=4)
    parser.add_argument("--crf", type=int, default=24)
    parser.add_argument("--width", type=int, default=1280)
    parser.add_argument("--height", type=int, default=720)
    parser.add_argument("--encoder", default="auto")
    args = parser.parse_args()

    folder = args.folder.resolve()
    if not folder.is_dir():
        print(f"[error] not a directory: {folder}", file=sys.stderr)
        return 1

    pvd_files = sorted(folder.rglob("particles.pvd"))
    if not pvd_files:
        print(f"[warn] no particles.pvd found under {folder}")
        return 0

    video_dir = folder / "video"
    video_dir.mkdir(parents=True, exist_ok=True)

    ok = 0
    failed = 0
    for pvd_path in pvd_files:
        # Use path relative to folder to create a unique stem
        try:
            rel = pvd_path.parent.relative_to(folder)
            parts = [p for p in rel.parts if p]
            stem = "_".join(parts) if parts else pvd_path.parent.name
        except ValueError:
            stem = pvd_path.parent.name

        if not stem:
            stem = "particles"

        out_path = video_dir / f"{stem}.mp4"
        print(f"[particletomp4] {pvd_path} -> {out_path}")

        vtp_paths = [p for p in parse_pvd(pvd_path) if p.exists()]
        if not vtp_paths:
            print(f"[warn] no existing VTP frames in {pvd_path}")
            failed += 1
            continue

        try:
            build_mp4(
                vtp_paths,
                out_path,
                fps=args.fps,
                cmap_name=args.cmap,
                width=args.width,
                height=args.height,
                title=stem,
                n_workers=args.workers,
                encoder=args.encoder,
                crf=args.crf,
            )
            ok += 1
        except Exception as exc:
            print(f"[error] failed to encode {pvd_path}: {exc}", file=sys.stderr)
            failed += 1

    print(f"[particletomp4] done: {ok} ok, {failed} failed. Videos in {video_dir}")
    return 0 if failed == 0 else 1


if __name__ == "__main__":
    raise SystemExit(main())
